# ARGUS Sentinel — Environment Configuration
# Copy this file to .env and fill in your credentials

# ── Google Gemini (FREE — no credit card needed) ──────────────────
# Get free key at: https://aistudio.google.com/app/apikey
# Free tier: 1,500 requests/day, 1M tokens/min
GOOGLE_API_KEY=your_google_api_key_here

# ── Bright Data ───────────────────────────────────────────────────
# Get from: https://brightdata.com → Account → API Tokens
BRIGHT_DATA_API_KEY=your_bright_data_api_key_here

# SERP API key (may differ from main API key)
# Get from: https://brightdata.com → Proxies & Scraping → SERP API
BRIGHT_DATA_SERP_KEY=your_bright_data_serp_key_here

# For proxy authentication (Web Unlocker + residential proxies)
BRIGHT_DATA_CUSTOMER_ID=your_customer_id_here
BRIGHT_DATA_PROXY_PASS=your_proxy_password_here

# ── Optional: Slack alerting ──────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ── Optional: Email alerting ─────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password
# ALERT_EMAIL_TO=analyst@company.com
